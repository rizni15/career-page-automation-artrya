{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:playwright/recommended",
    "plugin:prettier/recommended"
  ],
  "rules": {
    "no-unused-vars": "error", // Flags variables you created but didn't use
    "no-console": "warn", // Warns if you leave console.log in your tests
    "playwright/no-skipped-test": "warn", // Warns if you leave .skip()
    "playwright/expect-expect": "error", // Ensures every test has an assertion
    "prettier/prettier": ["error", { "endOfLine": "auto" }]
  }
}
